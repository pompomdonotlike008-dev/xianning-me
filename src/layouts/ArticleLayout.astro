---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  date: string;
  tag?: string;
  backUrl: string;
  backLabel: string;
}

const { title, description, date, tag, backUrl, backLabel } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title} — 贤宁</title>
    <SEO title={title} description={description} />
    <style>
      /* ===== Progress Bar ===== */
      .progress-bar {
        position: fixed;
        top: 56px;
        left: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent-blue), var(--accent-green));
        z-index: 99;
        width: 0%;
        transition: width 0.1s linear;
      }

      /* ===== Article Container ===== */
      .article-main {
        max-width: 680px;
        margin: 0 auto;
        padding: 100px var(--content-padding) 60px;
      }

      /* ===== Back Nav ===== */
      .back-nav {
        margin-bottom: 48px;
      }
      .back-nav a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.88rem;
        color: var(--text-tertiary);
        transition: color 0.2s;
      }
      .back-nav a:hover {
        color: var(--accent-blue);
        opacity: 1;
      }

      /* ===== Hero ===== */
      .article-hero {
        margin-bottom: 48px;
      }
      .article-hero h1 {
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.25;
        margin-bottom: 16px;
        color: var(--text-primary);
      }
      .article-meta {
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 0.9rem;
        color: var(--text-tertiary);
      }
      .article-meta time {
        font-variant-numeric: tabular-nums;
      }
      .article-tag {
        display: inline-flex;
        align-items: center;
        background: #f0f0f0;
        color: var(--text-secondary);
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 12px;
        border-radius: 100px;
        letter-spacing: 0.02em;
      }

      /* ===== Content Typography ===== */
      .article-content {
        font-family: 'Inter', 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
      }
      .article-content p {
        font-size: 1.1rem;
        line-height: 1.9;
        color: #2c2c2e;
        margin-bottom: 1.6em;
        letter-spacing: 0.004em;
        -webkit-font-smoothing: antialiased;
      }
      .article-content strong {
        font-weight: 700;
        color: #1a1a1a;
      }

      /* ===== Headings ===== */
      .article-content h2 {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: #1a1a1a;
        margin: 56px 0 16px;
        padding-bottom: 0;
        line-height: 1.35;
      }
      .article-content h2:first-child {
        margin-top: 0;
      }
      .article-content h3 {
        font-size: 1.2rem;
        font-weight: 600;
        color: #1a1a1a;
        margin: 36px 0 10px;
        line-height: 1.4;
      }

      /* ===== Section Divider ===== */
      .article-content hr {
        border: none;
        text-align: center;
        margin: 48px 0;
        overflow: visible;
        height: 0;
      }
      .article-content hr::after {
        content: '· · ·';
        color: var(--text-placeholder);
        font-size: 1.2rem;
        letter-spacing: 0.3em;
      }

      /* ===== Callout Box ===== */
      .article-content blockquote {
        border: none;
        border-left: 4px solid var(--accent-blue);
        background: linear-gradient(135deg, rgba(0,122,255,0.03) 0%, rgba(0,122,255,0.01) 100%);
        border-radius: 0 12px 12px 0;
        padding: 20px 24px;
        margin: 36px 0;
      }
      .article-content blockquote p {
        font-size: 1rem;
        color: #3a3a3c;
        margin-bottom: 0;
        line-height: 1.75;
      }
      .article-content blockquote p strong {
        color: #1a1a1a;
      }

      /* ===== Lists ===== */
      .article-content ul,
      .article-content ol {
        padding-left: 20px;
        margin-bottom: 1.6em;
      }
      .article-content li {
        font-size: 1.08rem;
        line-height: 1.9;
        color: #2c2c2e;
        margin-bottom: 6px;
        padding-left: 4px;
      }
      .article-content li::marker {
        color: var(--text-placeholder);
      }

      /* ===== Inline Code ===== */
      .article-content code {
        background: #f0f0f2;
        color: #1a1a1a;
        padding: 2px 8px;
        border-radius: 5px;
        font-family: var(--font-mono);
        font-size: 0.88em;
        font-weight: 500;
        letter-spacing: 0;
      }

      /* ===== Code Block ===== */
      .article-content pre {
        background: #1a1a1a;
        color: #e5e5e7;
        padding: 24px 28px;
        border-radius: 14px;
        overflow-x: auto;
        margin: 28px 0;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        line-height: 1.7;
        letter-spacing: 0;
        -webkit-font-smoothing: auto;
      }
      .article-content pre code {
        background: none;
        color: inherit;
        padding: 0;
        font-size: inherit;
      }

      /* ===== Tables ===== */
      .article-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 28px 0 36px;
        font-size: 0.95rem;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow-card);
      }
      .article-content thead {
        background: #f9f9fb;
      }
      .article-content th {
        text-align: left;
        padding: 12px 16px;
        font-weight: 600;
        font-size: 0.82rem;
        color: var(--text-secondary);
        text-transform: none;
        letter-spacing: 0.02em;
        border-bottom: 2px solid rgba(0,0,0,0.06);
      }
      .article-content td {
        padding: 12px 16px;
        border-bottom: 1px solid rgba(0,0,0,0.04);
        color: #2c2c2e;
        vertical-align: top;
      }
      .article-content tr:last-child td {
        border-bottom: none;
      }
      .article-content tbody tr:hover {
        background: rgba(0,0,0,0.01);
      }

      /* ===== Highlight Numbers in Tables ===== */
      .article-content td:has(strong) {
        font-weight: 500;
      }

      /* ===== Text Accents ===== */
      .article-content .text-green { color: var(--accent-green); font-weight: 700; }
      .article-content .text-red { color: #c62828; font-weight: 700; }
      .article-content .text-orange { color: var(--accent-orange); font-weight: 600; }

      /* ===== Skill Card Insets ===== */
      .skill-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
        margin: 24px 0 36px;
      }
      .skill-detail-card {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 20px 22px;
        box-shadow: var(--shadow-card);
        border-left: 3px solid var(--accent-blue);
      }
      .skill-detail-card h4 {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 6px;
        color: #1a1a1a;
      }
      .skill-detail-card p {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 0;
      }
      .skill-detail-card.red { border-left-color: #c62828; }
      .skill-detail-card.green { border-left-color: var(--accent-green); }
      .skill-detail-card.orange { border-left-color: var(--accent-orange); }

      /* ===== Checklist ===== */
      .article-content .checklist {
        list-style: none;
        padding-left: 0;
        margin: 20px 0 32px;
      }
      .article-content .checklist li {
        padding: 6px 0;
        font-size: 1.05rem;
      }
      .article-content .checklist li::before {
        content: '✓ ';
        color: var(--accent-green);
        font-weight: 700;
        margin-right: 6px;
      }
      .article-content .checklist li.fail::before {
        content: '✗ ';
        color: #c62828;
      }

      /* ===== Download Button ===== */
      .article-content .download-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--accent-green);
        color: #fff;
        padding: 14px 28px;
        border-radius: 14px;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 2px 12px rgba(52, 199, 89, 0.3);
      }
      .article-content .download-btn:hover {
        opacity: 1;
        transform: translateY(-1px);
        box-shadow: 0 4px 20px rgba(52, 199, 89, 0.4);
      }

      /* ===== Mobile ===== */
      @media (max-width: 640px) {
        .article-main {
          padding-top: 80px;
        }
        .article-content p {
          font-size: 1.02rem;
        }
        .article-content table {
          font-size: 0.82rem;
        }
        .article-content th, .article-content td {
          padding: 8px 10px;
        }
        .skill-detail-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <script>
      // Reading progress bar
      document.addEventListener('DOMContentLoaded', () => {
        const bar = document.querySelector('.progress-bar');
        if (!bar) return;
        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
          bar.style.width = progress + '%';
        });
      });
    </script>
  </head>
  <body>
    <div class="progress-bar"></div>
    <Header />
    <main class="article-main">
      <div class="back-nav">
        <a href={backUrl}>← {backLabel}</a>
      </div>
      <div class="article-hero">
        <h1>{title}</h1>
        <div class="article-meta">
          <time datetime={date}>{date}</time>
          {tag && <span class="article-tag">{tag}</span>}
        </div>
      </div>
      <div class="article-content">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
