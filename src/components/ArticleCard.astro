---
export interface Props {
  title: string;
  date: string;
  summary: string;
  href: string;
  tag?: string;
}

const { title, date, summary, href, tag } = Astro.props;
---

<article class="article-card card">
  <a href={href} class="article-link">
    <div class="article-header">
      <h3 class="article-title">{title}</h3>
      {tag && <span class="article-tag">{tag}</span>}
    </div>
    <p class="article-summary">{summary}</p>
    <time class="article-date" datetime={date}>{date}</time>
  </a>
</article>

<style>
  .article-card {
    padding: 24px 28px;
  }

  .article-link {
    display: block;
    color: inherit;
  }

  .article-link:hover {
    opacity: 1;
  }

  .article-link:hover .article-title {
    color: var(--accent-blue);
  }

  .article-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }

  .article-title {
    font-size: 1.15rem;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .article-tag {
    background: var(--accent-blue-bg);
    color: var(--accent-blue-text);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .article-summary {
    font-size: 0.92rem;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-date {
    font-size: 0.8rem;
    color: var(--text-placeholder);
  }
</style>
