---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="纸条随笔" description="一段段小故事，记录一个普通人的成长历程。不追求完整，追求真诚。">
  <div class="page-header">
    <h1>📝 纸条随笔</h1>
    <p>一段段小故事，慢慢讲</p>
  </div>

  <div class="story-gallery">
    <div class="story-card empty">
      <div class="story-number">01</div>
      <div class="story-preview">
        <h3>即将开始</h3>
        <p>这里会放第一个小故事。</p>
      </div>
    </div>
    <div class="story-card empty">
      <div class="story-number">02</div>
      <div class="story-preview">
        <h3>即将开始</h3>
        <p>故事还在路上。</p>
      </div>
    </div>
    <div class="story-card empty">
      <div class="story-number">03</div>
      <div class="story-preview">
        <h3>即将开始</h3>
        <p>不知道下一个故事会是什么。</p>
      </div>
    </div>
  </div>

  <div class="page-footer">
    <p>📱 关注公众号 <strong>「王炸小纸条」</strong></p>
    <p class="sub">阅读新能源 & AI 深度内容</p>
  </div>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    padding: 100px 0 48px;
  }

  .page-header h1 {
    margin-bottom: 8px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--text-placeholder);
  }

  .story-gallery {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .story-card {
    background: var(--bg-card);
    border-radius: var(--radius-card);
    padding: 32px 28px;
    box-shadow: var(--shadow-card);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .story-card.empty {
    opacity: 0.45;
    cursor: default;
  }

  .story-card:not(.empty):hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .story-number {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-placeholder);
    line-height: 1;
  }

  .story-preview h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .story-preview p {
    font-size: 0.88rem;
    color: var(--text-tertiary);
  }

  .page-footer {
    text-align: center;
    padding: 64px 0 40px;
  }

  .page-footer p {
    font-size: 1rem;
  }

  .page-footer .sub {
    font-size: 0.85rem;
    color: var(--text-placeholder);
    margin-top: 6px;
  }

  @media (max-width: 640px) {
    .story-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
